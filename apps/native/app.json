{
	"expo": {
		"scheme": "Pleises",
		"userInterfaceStyle": "automatic",
		"orientation": "default",
		"web": {
			"bundler": "metro"
		},
		"name": "Pleises",
		"slug": "Pleises",
		"plugins": [
			"expo-font",
			[
				"expo-camera",
				{
					"cameraPermission": "Allow Pleises to use your camera to capture places."
				}
			],
			[
				"expo-maps",
				{
					"requestLocationPermission": true,
					"locationPermission": "Allow Pleises to use your location to make sure you find your way to the places you want to go",
					"NSLocationWhenInUseUsageDescription": "Allow Pleises to use your location to make sure you find your way to the places you want to go"
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"ios": {
			"bundleIdentifier": "com.pohinagroup.pleises",
			"appleTeamId": "VKN9G4GC43"
		},
		"android": {
			"package": "com.pohinagroup.pleises",
			"permissions": [
				"android.permission.CAMERA",
				"android.permission.RECORD_AUDIO",
				"android.permission.ACCESS_COARSE_LOCATION",
				"android.permission.ACCESS_FINE_LOCATION"
			]
		},
		"extra": {
			"eas": {
				"projectId": "68506fd4-ea2f-4811-a918-940305252e3e"
			}
		}
	}
}

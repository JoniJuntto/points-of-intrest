{
	"cli": {
		"version": ">= 18.13.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal",
			"env": {
				"EXPO_PUBLIC_SERVER_URL": "https://poiapi.arvoitus.com"
			}
		},
		"production": {
			"autoIncrement": true,
			"env": {
				"EXPO_PUBLIC_SERVER_URL": "https://poiapi.arvoitus.com"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
